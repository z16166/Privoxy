<client>
<server>
http
</server>
<name>
Applying client-body-filter{blafasel-to-bumfidel} to client request that is too large to read at once and arrives slowly
</name>
<features>
proxy
</features>
<command>
--limit-rate 4k -d "blafasel%repeat[5000 x padding]%" http://%HOSTIP:%HTTPPORT/%TESTNUMBER
</command>
</client>

<verify>
<protocol nonewline="yes">
POST /%TESTNUMBER HTTP/1.1%CR
Host: %HOSTIP:%HTTPPORT%CR
User-Agent: curl/%VERSION%CR
Accept: */*%CR
Content-Length: 35008%CR
Content-Type: application/x-www-form-urlencoded%CR
Connection: close%CR
%CR
bumfidel%repeat[5000 x padding]%
</protocol>
</verify>
